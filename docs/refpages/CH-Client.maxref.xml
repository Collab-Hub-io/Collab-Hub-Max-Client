<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<?xml-stylesheet href="./_c74_ref.xsl" type="text/xsl"?>

<c74object name="CH-Client">

	<digest>
		Connect to the Collab-Hub Server. Client Module for Collab-Hub.
	</digest>
	
	<description>
	When using Collab-Hub, only one instance of the CH-Client module is needed. If you have more than one instance of the CH-Client module, disable all but one of them.
	<illustration><img src="images/CH-Client-Module.png" /></illustration>
	</description>
	
	<!--METADATA-->
	<metadatalist>
		<metadata name="author">Nick Hwang, Eric Sheffield, and Anthony T. Marasco</metadata>
		<metadata name="tag">Collab-Hub</metadata>
		<metadata name="tag">Networking</metadata>
		<metadata name="tag">Client</metadata>
	</metadatalist>
	
	<!--INLETS-->
	<inletlist>
		<inlet id="0" type="anythin">
			<digest>All Collab-Hub components have one inlet which can be used to send messages to the Server. Please see CH-Client for available messages.</digest>
		</inlet>
	</inletlist>

	<!--OUTLETS-->
	<outletlist>
		<outlet id="0" type="anything">
			<digest>Incoming data messages.</digest>
		</outlet>
	</outletlist>
	
	<!--ARGUMENTS-->
	<objarglist>
		<objarg name="enabled" optional="0" type="int (0/1)">
			<digest>Enable or disable the Client Module</digest>
		</objarg>
	</objarglist>
	
	<!--MESSAGES-->
	<methodlist>
		<method name="enable">
			<arglist>
				<arg name="0/1" optional="1" type="int (0/1)" />
			</arglist>
			<digest>
				Enable or disable the Client Module
			</digest>
			<description>
				Enables (1) or disables (0) the Client Module. When disabled, the Client Module will not connect to the Collab-Hub Server and will not send or receive any data.
			</description>
		</method>
		<method name="connect">
			<arglist />
			<digest>
				Connect to the Collab-Hub Server
			</digest>
			<description>
				Establishes a connection to the Collab-Hub Server using the specified server address and port.
			</description>
		</method>
